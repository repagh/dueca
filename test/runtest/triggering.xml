<?xml version='1.0' encoding='UTF-8'?>
<scenario xmlns="https://dueca.tudelft.nl/testscenario" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://dueca.tudelft.nl/testscenario https://dueca.tudelft.nl/schemas/testscenario.xsd">
  <!-- scenario description

    This uses the DuecaTestCommunication project to check some triggering logic.

    To recreate:

    - Calibrate offset, mouse to upper left corner of a window, press F3
    - Operate DUECA/DUSIME state machine to work
    - modify the timing for the stop, to give the simulation time to run the
      code
    - operate to off and exit
  -->
  <project name="DuecaTestCommunication">
    <window>DUECA/DUSIME control panel</window>
    <window>Are you serious?</window>
    <window>Activity View</window>
  </project>
  <repository>https://github.com/dueca/</repository>
  <buildoptions>-DUSE_GTK3=ON</buildoptions>
  <execute>
    <platform>solo</platform>
    <node>triggering</node>
  </execute>
  <offset x="0" y="16"/>
  <actions>
    <check window="DUECA/DUSIME control panel" x="460" y="59" r="65" g="255" b="11" timeout="10.0" wait="0.5"/>
    <check window="DUECA/DUSIME control panel" x="464" y="94" r="104" g="104" b="104" timeout="10.0" wait="0.5"/>
    <click window="DUECA/DUSIME control panel" x="464" y="94" button="Button.left" pressed="true" wait="0.2"/>
    <click window="DUECA/DUSIME control panel" x="464" y="94" button="Button.left" pressed="false" wait="0.2"/>
    <check window="DUECA/DUSIME control panel" x="464" y="94" r="65" g="255" b="11" timeout="10.0" wait="0.5"/>
    <check window="DUECA/DUSIME control panel" x="462" y="129" r="104" g="104" b="104" timeout="10.0" wait="0.5"/>
    <click window="DUECA/DUSIME control panel" x="462" y="129" button="Button.left" pressed="true" wait="0.2"/>
    <click window="DUECA/DUSIME control panel" x="462" y="129" button="Button.left" pressed="false" wait="0.2"/>
    <check window="DUECA/DUSIME control panel" x="462" y="129" r="65" g="255" b="11" timeout="10.0" wait="0.5"/>
    <click window="DUECA/DUSIME control panel" x="56" y="5" button="Button.left" pressed="true" wait="0.2"/>
    <click window="DUECA/DUSIME control panel" x="56" y="5" button="Button.left" pressed="false" wait="0.2"/>
    <check window="DUECA/DUSIME control panel" x="152" y="38" r="53" g="132" b="228" timeout="10.0" wait="0.5"/>
    <click window="DUECA/DUSIME control panel" x="152" y="38" button="Button.left" pressed="true" wait="0.2"/>
    <click window="DUECA/DUSIME control panel" x="152" y="38" button="Button.left" pressed="false" wait="0.2"/>
    <check window="Activity View" x="99" y="28" r="248" g="248" b="247" timeout="10.0" wait="0.5"/>
    <click window="Activity View" x="99" y="28" button="Button.left" pressed="true" wait="0.2"/>
    <click window="Activity View" x="99" y="28" button="Button.left" pressed="false" wait="0.2"/>
    <check window="DUECA/DUSIME control panel" x="461" y="96" r="104" g="104" b="104" timeout="10.0" wait="10.5"/>
    <click window="DUECA/DUSIME control panel" x="461" y="96" button="Button.left" pressed="true" wait="0.2"/>
    <click window="DUECA/DUSIME control panel" x="461" y="96" button="Button.left" pressed="false" wait="0.2"/>
