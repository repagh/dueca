  <!-- scenario description

    This uses the SimpleSimulation project, which creates a simple multiplayer.

    To recreate:

    - Calibrate offset, mouse to upper left corner of a window, press F3
    - Operate DUECA/DUSIME state machine for the central server to work
    - Operate the team1 and team2 to hold
    - Operate team1 to advance; should be visible in team2 image
    - Operate team2 to advance
      - Take a snapshot
    - Operate the teams to off and exit
    - Operate central to off and exit
  -->
  <project name="SimpleSimulation">
    <window>DUECA/DUSIME control panel</window>
    <window>Team 1</window>
    <window>Team 2</window>
    <window>Are you serious?</window>
    <window>TEAM 1 control panel</window>
    <window>front</window>
    <window>TEAM 2 control panel</window>
    <window>team2</window>
    <window>team1</window>
  </project>
  <repository>https://github.com/dueca/</repository>
  <buildoptions>-DUSE_GTK3=ON</buildoptions>
  <execute>
    <platform>multi</platform>
    <node>central</node>
  </execute>
  <execute>
    <platform>multi</platform>
    <node>team1</node>
  </execute>
  <execute>
    <platform>multi</platform>
    <node>team2</node>
  </execute>
