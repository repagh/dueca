<?xml version='1.0' encoding='UTF-8'?>
<scenario xmlns="https://dueca.tudelft.nl/testscenario" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://dueca.tudelft.nl/testscenario https://dueca.tudelft.nl/schemas/testscenario.xsd">
  <!-- scenario description

    This uses the DuecaTestCommunication project with websock communication and a
    python script as counterpart.

    To recreate:

    - The same scenario from tmssolo.xml can be used. Increate timeout for the
      initial wait a bit.

    - Calibrate offset, mouse to upper left corner of a window, press F3
    - Operate DUECA/DUSIME state machine for the central server to work
    - modify the timing for the stop, to give the simulation time to comminicate
    - operate to off and exit
  -->
  <project name="DuecaTestCommunication">
    <window>DUECA/DUSIME control panel</window>
    <window>Are you serious?</window>
  </project>
  <repository>https://github.com/dueca/</repository>
  <buildoptions>-DUSE_GTK3=ON</buildoptions>
  <execute>
    <platform>solo</platform>
    <node>websock</node>
    <command>./runscript</command>
  </execute>
  <offset x="-2" y="16" criterion="0.995" template-pattern="/gtk3/*.png"/>
  <actions>
    <check-image window="DUECA/DUSIME control panel" x="459" y="59" template="buttongreensel" testsize="64" timeout="20.0" wait="0.5"/>
