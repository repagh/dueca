    <check-image window="DUECA/DUSIME control panel" x="459" y="59" template="buttongreensel" testsize="64" timeout="10.0" wait="0.5"/>
    <check-word window="DUECA/DUSIME control panel" x="14" y="11" word="File" testsize="64" timeout="10.0" wait="0.5" criterion="30"/>
