<?xml version="1.0" encoding="UTF-8"?>
<scenario xmlns="https://dueca.tudelft.nl/testscenario" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://dueca.tudelft.nl/testscenario https://dueca.tudelft.nl/schemas/testscenario.xsd">
  <!-- scenario description

    This uses the DuecaTestCommunication project in its simplest way possible,
    but with the simulation distributed over two nodes.

    To recreate:

    - The same scenario from tmssolo.xml can be used. Increate timeout for the
      initial wait a bit

    - Calibrate offset, mouse to upper left corner of a window, press F3
    - Operate DUECA/DUSIME state machine for the central server to work
    - modify the timing for the stop, to give the simulation time to create/
      delete flasher blips
    - operate to off and exit
  -->
  <project name="DuecaTestCommunication">
    <window>DUECA/DUSIME control panel</window>
    <window>Are you serious?</window>
  </project>
  <repository>https://github.com/dueca/</repository>
  <buildoptions>-DUSE_GTK3=ON</buildoptions>
  <execute>
    <platform>udp-two</platform>
    <node>node2</node>
  </execute>
  <execute>
    <platform>udp-two</platform>
    <node>node1</node>
  </execute>
  <offset x="-2" y="16" criterion="0.995" template-pattern="/gtk3/*.png"/>
  <actions>
    <check-image window="DUECA/DUSIME control panel" x="459" y="58" template="buttongreensel" testsize="64" timeout="30.0" wait="0.5"/>
    <check-image window="DUECA/DUSIME control panel" x="462" y="93" template="buttongraysel" testsize="64" timeout="10.0" wait="0.5"/>
    <click relative="true" x="2" y="-2" button="Button.left" pressed="true" wait="0.3"/>
    <click relative="true" x="2" y="-2" button="Button.left" pressed="false" wait="0.3"/>
    <check-image window="DUECA/DUSIME control panel" x="462" y="93" template="buttongreensel" testsize="64" timeout="30.0" wait="0.5"/>
    <check-image window="DUECA/DUSIME control panel" x="458" y="133" template="buttongraysel" testsize="64" timeout="10.0" wait="0.5"/>
    <click relative="true" x="-2" y="2" button="Button.left" pressed="true" wait="0.3"/>
    <click relative="true" x="-2" y="2" button="Button.left" pressed="false" wait="0.3"/>
    <check-image window="DUECA/DUSIME control panel" x="458" y="133" template="buttongreensel" testsize="64" timeout="20.0" wait="0.5"/>
    <check-image window="DUECA/DUSIME control panel" x="459" y="161" template="buttongreensel" testsize="64" timeout="10.0" wait="0.5"/>
    <check-image window="DUECA/DUSIME control panel" x="460" y="197" template="buttongraysel" testsize="64" timeout="10.0" wait="0.5"/>
    <click relative="true" x="0" y="-4" button="Button.left" pressed="true" wait="0.3"/>
    <click relative="true" x="0" y="-4" button="Button.left" pressed="false" wait="0.3"/>
    <check-image window="DUECA/DUSIME control panel" x="462" y="201" template="buttongreensel" testsize="64" timeout="10.0" wait="0.5"/>
    <check-image window="DUECA/DUSIME control panel" x="418" y="198" template="buttongraysel" testsize="64" timeout="10.0" wait="0.5"/>
    <click relative="true" x="2" y="-3" button="Button.left" pressed="true" wait="0.3"/>
    <click relative="true" x="2" y="-3" button="Button.left" pressed="false" wait="0.3"/>
    <check-image window="DUECA/DUSIME control panel" x="418" y="198" template="buttongraysel" testsize="64" timeout="10.0" wait="0.5"/>
    <check-image window="DUECA/DUSIME control panel" x="459" y="235" template="buttongraysel" testsize="64" timeout="10.0" wait="0.5"/>
    <click relative="true" x="-1" y="0" button="Button.left" pressed="true" wait="0.3"/>
    <click relative="true" x="-1" y="0" button="Button.left" pressed="false" wait="0.3"/>
    <snap name="tmssolo000.png"/>
    <check-image window="DUECA/DUSIME control panel" x="458" y="201" template="buttongraysel" testsize="64" timeout="10.0" wait="8.5"/>
