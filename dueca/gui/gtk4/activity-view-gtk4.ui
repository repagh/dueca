<?xml version='1.0' encoding='UTF-8'?>
<!-- Created with Cambalache 0.10.3 -->
<interface>
  <requires lib="gtk" version="4.6"/>
  <object class="GtkListStore" id="activitylist">
    <columns>
      <column type="gchararray"/>
      <column type="gchararray"/>
      <column type="gchararray"/>
      <column type="gchararray"/>
      <column type="gchararray"/>
      <column type="gchararray"/>
    </columns>
  </object>
  <object class="GtkAdjustment" id="adjustment_recordspan">
    <property name="lower">0.01</property>
    <property name="upper">2</property>
    <property name="value">0.20</property>
    <property name="step-increment">0.01</property>
    <property name="page-increment">0.10</property>
  </object>
  <object class="GtkAdjustment" id="adjustment_viewspan">
    <property name="lower">0.01</property>
    <property name="upper">2</property>
    <property name="value">0.10</property>
    <property name="step-increment">0.01</property>
    <property name="page-increment">0.10</property>
  </object>
  <object class="GtkWindow" id="activity_view">
    <property name="title" translatable="1">Activity View</property>
    <child>
      <object class="GtkBox">
        <property name="orientation">vertical</property>
        <child>
          <object class="GtkBox">
            <child>
              <object class="GtkButton" id="view_close">
                <property name="icon-name">window-close</property>
                <property name="label">close</property>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="view_update">
                <property name="icon-name">view-refresh</property>
                <property name="label">update</property>
              </object>
            </child>
            <child>
              <object class="GtkGrid">
                <property name="row-homogeneous">True</property>
                <child>
                  <object class="GtkLabel">
                    <property name="justify">right</property>
                    <property name="label">record span</property>
                    <property name="yalign">0.8</property>
                    <layout>
                      <property name="column">0</property>
                      <property name="column-span">1</property>
                      <property name="row">0</property>
                      <property name="row-span">1</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="GtkLabel">
                    <property name="label">view span</property>
                    <layout>
                      <property name="column">0</property>
                      <property name="column-span">1</property>
                      <property name="row">1</property>
                      <property name="row-span">1</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="GtkScale" id="recordspan">
                    <property name="digits">2</property>
                    <property name="draw-value">True</property>
                    <property name="width-request">150</property>
                    <property name="adjustment">adjustment_recordspan</property>
                    <layout>
                      <property name="column">1</property>
                      <property name="column-span">1</property>
                      <property name="row">0</property>
                      <property name="row-span">1</property>
                    </layout>
                  </object>
                </child>
                <child>
                  <object class="GtkScale" id="viewspan">
                    <property name="digits">2</property>
                    <property name="draw-value">True</property>
                    <property name="width-request">150</property>
                    <property name="adjustment">adjustment_viewspan</property>
                    <layout>
                      <property name="column">1</property>
                      <property name="column-span">1</property>
                      <property name="row">1</property>
                      <property name="row-span">1</property>
                    </layout>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
  </object>
</interface>
